    <!-- Étape 3 : USB Kill                                                  -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <string name="usb_title">USB Kill</string>

    <string name="usb_admin_required">Device Admin required</string>
    <string name="usb_admin_required_desc">Enable Device Admin on the Wipe test screen before turning on USB Kill, otherwise the wipe will fail silently.</string>

    <string name="usb_master_title">USB Kill enabled</string>
    <string name="usb_master_desc">Runs a persistent foreground service that watches for charger/USB plug-in events while the screen is locked.</string>

    <string name="usb_grace_title">Grace period</string>
    <string name="usb_grace_desc">Delay between detecting a plug-in and wiping. Unplug before the countdown ends to abort.</string>
    <string name="usb_grace_value">%1$d seconds</string>
    <string name="usb_grace_value_immediate">Immediate wipe (0 s)</string>

    <string name="usb_notif_perm_title">Notification permission</string>
    <string name="usb_notif_perm_desc">Android 13+ requires explicit permission to post notifications. Without it the USB Kill countdown notification will be hidden (the service still works but you cannot see or cancel the countdown).</string>
    <string name="usb_notif_perm_grant">Grant permission</string>

    <string name="usb_rules_title">Rules</string>
    <string name="usb_rules_body">• Triggers only when the screen is locked.\n• Plug-in while locked → countdown starts.\n• Unplug during countdown → aborts.\n• Countdown reaches zero → wipe.</string>

    <!-- Notification -->
    <string name="usb_channel_name">USB Kill</string>
