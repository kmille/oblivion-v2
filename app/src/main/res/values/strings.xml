    <!-- Dead Man\'s Switch                                                 -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <string name="deadman_title">Dead Man\'s Switch</string>

    <string name="deadman_admin_required">Device Admin required</string>
    <string name="deadman_admin_required_desc">Enable Device Admin on the Wipe test screen before turning on the Dead Man\'s Switch.</string>

    <string name="deadman_master_title">Switch enabled</string>
    <string name="deadman_master_desc">If you do not unlock the app via biometrics/PIN during the interval below, the device is wiped automatically. Silent: no notification.</string>

    <string name="deadman_interval_title">Inactivity interval</string>
    <string name="deadman_interval_desc">Choose hours or days. Any biometric authentication in the app resets the countdown.</string>
    <string name="deadman_unit_hours">Hours</string>
    <string name="deadman_unit_days">Days</string>
    <string name="deadman_value_hours_label">Hours (1–1440)</string>
    <string name="deadman_value_days_label">Days (1–60)</string>

    <string name="deadman_status_title">Status</string>
    <string name="deadman_status_disabled">Switch disabled.</string>
    <string name="deadman_status_no_checkin">No check-in yet.</string>
    <string name="deadman_status_last_checkin">Last check-in: %1$s</string>
    <string name="deadman_status_remaining">Time before wipe: %1$s</string>
    <string name="deadman_status_expired">Expired — wipe imminent.</string>
    <string name="deadman_checkin_now">Check-in now</string>

    <string name="deadman_rules_title">Rules</string>
    <string name="deadman_rules_body">• The countdown resets every time you unlock the app via biometrics.\n• A periodic background task checks the deadline (every 15 min).\n• Works even when the app is closed (as long as Android has not killed the WorkManager job).\n• 100%% silent: no notification, no alert.\n• Minimum 1 hour, maximum 60 days.</string>

