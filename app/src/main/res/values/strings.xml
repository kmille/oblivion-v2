    <!-- Scheduled Wipe                                                     -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <string name="scheduled_title">Scheduled wipe</string>

    <string name="scheduled_admin_required">Device Admin required</string>
    <string name="scheduled_admin_required_desc">Enable Device Admin on the Wipe test screen before arming the scheduled wipe.</string>

    <string name="scheduled_exact_alarm_title">Exact alarm permission</string>
    <string name="scheduled_exact_alarm_desc">Android 12+ restricts exact alarms. Grant permission so the scheduled wipe fires at the chosen time.</string>
    <string name="scheduled_exact_alarm_grant">Grant in settings</string>

    <string name="scheduled_arm_title">Arm the wipe</string>
    <string name="scheduled_arm_desc">Choose a date and time in the future. When reached, the device is wiped silently — no pre-alert.</string>
    <string name="scheduled_arm_selected">Selected: %1$s</string>
    <string name="scheduled_pick_date">Date</string>
    <string name="scheduled_pick_time">Time</string>
    <string name="scheduled_arm_button">Arm wipe</string>

    <string name="scheduled_armed_title">Wipe armed</string>
    <string name="scheduled_armed_at">Scheduled for %1$s</string>
    <string name="scheduled_armed_remaining">Time remaining: %1$s</string>
    <string name="scheduled_armed_expired">Expired — wipe imminent.</string>
    <string name="scheduled_disarm_hint">Disarming requires biometric authentication.</string>
    <string name="scheduled_disarm_button">Disarm (biometric)</string>
    <string name="scheduled_disarm_prompt_title">Disarm scheduled wipe</string>
    <string name="scheduled_disarm_prompt_subtitle">Authenticate to cancel the scheduled wipe.</string>

    <string name="scheduled_rules_title">Rules</string>
    <string name="scheduled_rules_body">• AlarmManager triggers at the chosen exact time, even in Doze.\n• Re-armed automatically after reboot.\n• 100%% silent: no notification, no pre-alert.\n• Cancelling requires biometric authentication.\n• If Device Admin is revoked between arming and firing, the wipe is dropped.</string>

