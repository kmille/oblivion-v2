    <!-- Decoy Mode (Option A)                                              -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <string name="decoy_title">Decoy mode</string>

    <string name="decoy_admin_required">Device Admin required</string>
    <string name="decoy_admin_required_desc">Decoy mode needs Device Admin active to actually wipe. Enable it from the dashboard.</string>

    <string name="decoy_notif_permission_section">Notification permissions</string>
    <string name="decoy_notif_perm_title">Notification permission</string>
    <string name="decoy_notif_perm_desc">Android 13+ requires explicit permission to post notifications. Without it the fake &quot;System update&quot; screen cannot be triggered at all (the wipe would not be launched either, because the trigger goes through a notification).</string>
    <string name="decoy_notif_perm_grant">Grant notification permission</string>

    <string name="decoy_fsi_required">Full-screen notifications required</string>
    <string name="decoy_fsi_required_desc">On Android 14+, the fake &quot;System update&quot; screen is launched through a full-screen notification (same mechanism as incoming-call apps). This permission must be granted manually. Without it the wipe still fires, but the decoy screen will appear as a heads-up notification instead of fullscreen.</string>
    <string name="decoy_fsi_grant">Open permission settings</string>

    <!-- Notification channel used for the fake update FullScreenIntent -->
    <string name="decoy_channel_name">System update</string>
    <string name="decoy_channel_desc">Silent channel used to display the fake Android system-update screen over the lockscreen when the decoy PIN is typed.</string>

    <string name="decoy_master_title">Decoy mode enabled</string>
    <string name="decoy_master_desc">When armed, typing the decoy PIN on the lockscreen triggers a silent wipe AND shows a fake Android system-update screen to hide the trigger from an attacker.</string>

    <string name="decoy_pin_title">Decoy PIN</string>
    <string name="decoy_pin_desc">Choose a short digit sequence (different from your real unlock PIN). When this sequence is typed on the lockscreen, the wipe fires.</string>
    <string name="decoy_pin_configured">PIN configured ✓</string>
    <string name="decoy_pin_not_configured">No PIN set yet</string>
    <string name="decoy_pin_input_label">Decoy PIN (digits only)</string>
    <string name="decoy_pin_min_hint">Minimum %1$d digits</string>
    <string name="decoy_pin_save">Save PIN</string>
    <string name="decoy_pin_clear">Clear PIN</string>

    <string name="decoy_rules_title">Rules</string>
    <string name="decoy_rules_body">• Uses the Guard accessibility service (lockscreen monitoring).\n• Independent from the Guard master switch — works alone.\n• PIN is stored as SHA-256 + salt, never in clear.\n• On match: wipe in background + fullscreen fake &quot;System update&quot; screen.\n• The fake update UI is uncloseable; the wipe finishes under the cover.\n• Use a sequence you would never type by accident.</string>

    <!-- DecoyOverlay (fake system update screen) -->
    <string name="decoy_update_title">System update</string>
    <string name="decoy_update_subtitle">Installing update…</string>
    <string name="decoy_update_note">Do not turn off your device.</string>
</resources>
