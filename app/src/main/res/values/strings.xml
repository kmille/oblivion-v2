    <!-- Étape 5 : Voice Wipe                                                -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <string name="voice_title">Voice Wipe</string>

    <string name="voice_admin_required">Device Admin required</string>
    <string name="voice_admin_required_desc">Enable Device Admin on the Wipe test screen before turning on Voice Wipe.</string>

    <string name="voice_perm_notif_title">Notification permission</string>
    <string name="voice_perm_notif_desc">Grant notification permission so the Voice Wipe service can show its status.</string>
    <string name="voice_perm_mic_title">Microphone permission</string>
    <string name="voice_perm_mic_desc">Voice Wipe needs the microphone to listen for the trigger phrase when the screen is locked.</string>
    <string name="voice_perm_grant">Grant permission</string>

    <string name="voice_model_title">Vosk model (offline)</string>
    <string name="voice_model_desc">Voice Wipe uses the Vosk small model (~40 MB per language), 100 %% offline. Two languages are supported: French (assets/model-fr/) and English (assets/model-en/).\n\nIf a model is missing, download it from alphacephei.com/vosk/models:\n• FR: vosk-model-small-fr-pguyot\n• EN: vosk-model-small-en-us-0.15\n\nExtract the ZIP and copy its contents into the matching assets/model-&lt;lang&gt;/ folder, then rebuild the APK.</string>
    <string name="voice_lang_title">Voice recognition language</string>
    <string name="voice_lang_desc">Select the Vosk model to use. The model must be present in app/src/main/assets/model-&lt;code&gt;/.</string>
    <string name="voice_lang_fr">French</string>
    <string name="voice_lang_en">English</string>

    <string name="voice_phrase_title">Trigger phrase</string>
    <string name="voice_phrase_desc">Pronounce this phrase while the screen is locked and the mic will trigger the wipe.</string>
    <string name="voice_phrase_label">Phrase</string>
    <string name="voice_phrase_bounds">Between %1$d and %2$d characters</string>
    <string name="voice_phrase_unsaved">Unsaved — tap Save</string>
    <string name="voice_phrase_save">Save phrase</string>

    <string name="voice_strict_title">Strict match</string>
    <string name="voice_strict_on_desc">Exact match: the recognized text must match the phrase exactly. Fewer false positives, may miss in noisy environments.</string>
    <string name="voice_strict_off_desc">Approximate match: the recognized text must contain the phrase. More tolerant in noisy environments, but higher risk of false positives.</string>

    <string name="voice_master_title">Voice Wipe enabled</string>
    <string name="voice_master_desc">Runs a foreground service that listens for the trigger phrase when the screen is locked. Micro access requires an explicit Android permission.</string>

    <string name="voice_rules_title">Rules</string>
    <string name="voice_rules_body">• The mic is only active when the screen is locked.\n• When unlocked, the mic is off (battery + privacy).\n• On phrase detection → immediate wipe.\n• Vosk runs 100 %% offline — no data leaves the device.</string>

    <!-- Notification -->
    <string name="voice_channel_name">Voice Wipe</string>
