<?xml version="1.0" encoding="utf-8"?>
<!--
   Interdit toute extraction des données de l'app par ADB backup ou
   "Device Transfer" (changement de téléphone).  Critique car l'app
   contient les déclencheurs de wipe.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
